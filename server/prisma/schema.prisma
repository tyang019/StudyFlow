generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  resources Resource[]
}

model Resource {
  id        Int     @id @default(autoincrement())
  title     String
  type      String
  completed Boolean

  userId Int
  user   User @relation(fields: [userId], references: [id])
}